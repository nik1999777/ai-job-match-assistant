# LLM Provider: "openai" or "ollama"
LLM_PROVIDER=openai
# temperature=0.0 for reproducible eval; increase for more creative responses
LLM_TEMPERATURE=0.0
# context limits — tune per model: llama3=4000/2000, gpt-4o=20000/8000, claude=50000/20000
RESUME_CONTEXT_LIMIT=4000
VACANCY_CONTEXT_LIMIT=2000

# OpenAI (used when LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Ollama (used when LLM_PROVIDER=ollama, run: ollama serve)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# PostgreSQL — docker-compose maps host:5433 → container:5432
DATABASE_URL=postgresql+asyncpg://jobmatch:jobmatch@localhost:5433/jobmatch

# Qdrant — docker-compose maps 6333:6333
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=vacancies

# App
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:5173"]
