# ==============================================================================
# LLM PROVIDER
# ==============================================================================
# Choose one: "openai" | "groq" | "ollama"
LLM_PROVIDER=groq

# temperature=0.0 → reproducible results (recommended for eval + prod)
LLM_TEMPERATURE=0.0

# Context sent to the LLM. Increase for bigger models, decrease for small/local.
#   llama3 (4B-8B local) : 4000 / 2000
#   llama-4-scout / 8b   : 8000 / 2000
#   gpt-4o / 70b+        : 20000 / 4000
RESUME_CONTEXT_LIMIT=8000
VACANCY_CONTEXT_LIMIT=2000

# ==============================================================================
# GROQ  (free tier, no credit card)  https://console.groq.com
# Limits dashboard : https://console.groq.com/dashboard
# Proxy needed from Russia — set GROQ_PROXY (leave empty outside RU)
# Server must be started without system proxy:
#   env -u HTTP_PROXY -u HTTPS_PROXY uvicorn api.main:app --port 8000
# ==============================================================================
GROQ_API_KEY=gsk_...
GROQ_PROXY=                        # http://user:pass@host:port  (blank = direct)

# ─── Available Groq models (free tier) ────────────────────────────────────────
#
# MODEL                                    SIZE    TPD*    QUALITY   NOTES
# ─────────────────────────────────────────────────────────────────────────────
# meta-llama/llama-4-scout-17b-16e-instruct  17B MoE  ~500K  ★★★★☆  best free choice
# llama-3.3-70b-versatile                   70B      100K   ★★★★★  smartest, low quota
# llama-3.1-8b-instant                       8B      500K   ★★★☆☆  fast, high quota
# qwen/qwen3-32b                            32B      ~100K  ★★★★☆  Alibaba, strong reasoning
# openai/gpt-oss-120b                      120B     ~100K  ★★★★★  ⚠ may lack tool calling
# groq/compound-beta                         –        –      ★★★★☆  Groq's own (beta)
# groq/compound-beta-mini                    –        –      ★★★☆☆  Groq's own, fast (beta)
#
# *TPD = Tokens Per Day (free on-demand tier). Resets midnight UTC.
#  Exact limits: https://console.groq.com/dashboard  → "Rate Limits"
# ─────────────────────────────────────────────────────────────────────────────
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# ==============================================================================
# OPENAI  (paid, production)
# ==============================================================================
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ==============================================================================
# OLLAMA  (free, local — run: ollama serve)
# ==============================================================================
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ==============================================================================
# INFRASTRUCTURE
# ==============================================================================
# PostgreSQL — docker-compose maps host:5433 → container:5432
DATABASE_URL=postgresql+asyncpg://jobmatch:jobmatch@localhost:5433/jobmatch

# Qdrant vector DB — docker-compose maps 6333:6333
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=vacancies

# ==============================================================================
# APP
# ==============================================================================
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:5173"]

# JWT auth
JWT_SECRET=your-secret-key-here
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080   # 7 days

# ==============================================================================
# LANGFUSE  — LLM tracing  http://localhost:3000
# 1. docker compose up -d langfuse
# 2. Register at http://localhost:3000
# 3. Settings → API Keys → paste below
# ==============================================================================
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
